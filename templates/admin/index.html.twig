{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content %}
    <div class="admin-dashboard">
        <div class="admin-dashboard-header">
            <div class="admin-dashboard-title">
                <h1>Panel d’administration</h1>
                <p>
                    Bonjour
                    {% if user %}
                        <strong>{{ user.pseudo ?? user.userIdentifier }}</strong>,
                    {% endif %}
                    bienvenue sur le tableau de bord de Iron Front.
                </p>
            </div>

            <div class="admin-dashboard-back-btn">
                <a href="{{ path('home', {'_locale': app.request.locale|default('fr')}) }}">
                    <i class="fa fa-arrow-left"></i> Retourner sur le site
                </a>
            </div>
        </div>

        <div class="admin-dashboard-grid">
            <div class="admin-card admin-card-big">
                <h3>Vue d’ensemble</h3>
                <p>Utilisez le menu de gauche pour accéder aux différentes sections.</p>
            </div>

            <div class="admin-card">
                <h3>Utilisateurs</h3>
                <p>Visualisez les comptes, ajustez certains paramètres si besoin (rôles, etc.).</p>
            </div>
        </div>
    </div>
{% endblock %}