{% extends 'base.html.twig' %}

{% block title %}Choix de faction{% endblock %}

{% block body %}
    <div id="form" class="form-background">
        <div class="form">
            <div class="form-content">
                <div class="mix">
                    <div class="headline">
                        <h3 class="text-headline">Choisissez votre faction</h3>
                        <p class="text-subheadline">Choisissez une faction et rejoignez une partie existante.</p>
                    </div>
                </div>

                {{ form_start(form, { attr: { class: 'all-form' } }) }}
                    <div class="games-grid">
                        <h4>Sélectionnez une partie</h4>
                        {% for game_field in form.game %}
                            <div class="game-card">
                                <label class="game-label">
                                    {{ form_widget(game_field) }}
                                    <div class="game-content">
                                        <h4 class="game-name">{{ game_field.vars.label }}</h4>
                                        <p class="game-description">{{ game_field.vars.attr['data-description'] }}</p>
                                    </div>
                                </label>
                            </div>
                        {% endfor %}
                    </div>

                    <hr>

                    <div class="factions-grid">
                        <h4>Sélectionnez votre faction</h4>
                        {% for faction_field in form.faction %}
                            <div class="faction-card">
                                <label class="faction-label">
                                    {{ form_widget(faction_field) }}
                                    <div class="faction-content">
                                        <h4 class="faction-name">{{ faction_field.vars.label }}</h4>
                                        <p class="faction-description">{{ faction_field.vars.attr['data-description'] }}</p>
                                    </div>
                                </label>
                            </div>
                        {% endfor %}
                    </div>

                    <div style="text-align: center; margin-top: 2rem;">
                        <button class="btn btn-lg btn-primary" type="submit">Rejoindre cette faction</button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}